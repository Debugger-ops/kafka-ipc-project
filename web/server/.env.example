# Copy to .env and adjust as needed.

# HTTP port the Express/Socket.IO server listens on
PORT=4000

# Kafka broker (same one the Java producer/consumer use)
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=ipc-events
# Consumer group for THIS bridge. Keep it different from the Java
# ipc-consumer-group so the web bridge sees every event independently.
KAFKA_GROUP_ID=web-bridge-group

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/kafka_ipc

# Where the React dev server runs (for CORS)
CLIENT_ORIGIN=http://localhost:5173
